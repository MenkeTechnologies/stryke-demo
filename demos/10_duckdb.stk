#!/usr/bin/env stryke
# demos/10_duckdb.stk — exercises every public stryke-duckdb API fn.
#
# Run:  s demos/10_duckdb.stk

use DuckDB
use Arrow

p "── stryke-duckdb demo (full API) ──"



# ── DuckDB::version ──
p "DuckDB::version " . DuckDB::version()

# ── DuckDB::ping ──
p "DuckDB::ping: " . (DuckDB::ping() ? "ok" : "down")

# ── DuckDB::inspect (in-memory) ──
val ($mem) = DuckDB::inspect()
p "DuckDB::inspect in-mem file=$mem->{file}"

# ── DuckDB::query ──
val @r = DuckDB::query "SELECT 1+1 AS two, 'hi' AS s"
p "DuckDB::query two=$r[0]->{two}"
val @r_lim = DuckDB::query("SELECT n FROM range(20) AS t(n)", limit => 4)
p "DuckDB::query limit=4 #{len(@r_lim)} rows"

# ── DuckDB::query (bind) ──
val @r_bind = DuckDB::query("SELECT ? AS x, ? AS y", bind => [42, "bound"])
p "DuckDB::query bind x=$r_bind[0]->{x} y=$r_bind[0]->{y}"
val @r_bind2 = DuckDB::query("SELECT n FROM range(?) AS t(n) WHERE n > ?",
    bind => [10, 5], limit => 3)
p "DuckDB::query bind+limit #{len(@r_bind2)} rows"

# ── DuckDB::query (columnar) ──
val ($cw) = DuckDB::query("SELECT n FROM range(3) AS t(n)", columnar => 1)
p "DuckDB::query columnar cols: " . join(",", sort keys %{ $cw->{columns} // {} })
val ($cw2) = DuckDB::query("SELECT n, n*2 AS d FROM range(5) AS t(n)",
    columnar => 1, limit => 3)
p "DuckDB::query columnar+limit cols: " . join(",", sort keys %{ $cw2->{columns} // {} })

# ── DuckDB::query (with_meta) ──
val ($meta) = DuckDB::query("SELECT * FROM range(2) AS t(n)", with_meta => 1)
p "DuckDB::query with_meta rows=#{len($meta->{rows})}"
val ($meta2) = DuckDB::query("SELECT n FROM range(10) AS t(n)",
    with_meta => 1, limit => 4)
p "DuckDB::query with_meta+limit rows=#{len($meta2->{rows})}"

# ── DuckDB::query_scalar ──
p "DuckDB::query_scalar count=" . DuckDB::query_scalar("SELECT COUNT(*) FROM range(100)")
p "DuckDB::query_scalar bind=" .
    DuckDB::query_scalar("SELECT SUM(n) FROM range(?) AS t(n)", bind => [6])

# ── DuckDB::query_one ──
val ($one) = DuckDB::query_one("SELECT 42 AS answer")
p "DuckDB::query_one answer=$one->{answer}"
val ($one2) = DuckDB::query_one("SELECT ? AS v", bind => ["hello"])
p "DuckDB::query_one bind v=$one2->{v}"

# ── DuckDB::query_col ──
val @col = DuckDB::query_col("SELECT n FROM range(4) AS t(n)")
p "DuckDB::query_col " . join(",", @col)
val @col2 = DuckDB::query_col("SELECT n FROM range(20) AS t(n)", limit => 5)
p "DuckDB::query_col limit=5 " . join(",", @col2)

# ── DuckDB::query_stream ──
val $sn = DuckDB::query_stream("SELECT n FROM range(50) AS t(n)",
    callback => fn ($r) { 1 })
p "DuckDB::query_stream $sn rows"
val $sn2 = DuckDB::query_stream("SELECT n FROM range(100) AS t(n) WHERE n > ?",
    bind => [90], limit => 5, callback => fn ($r) { 1 })
p "DuckDB::query_stream bind+limit $sn2 rows"

val $tmp = "/tmp/stryke-demo-duckdb"
mkdir $tmp unless -d $tmp
val $db = "/tmp/stryke-demo-duckdb-$$.duckdb"
val $pq = "$tmp/people.parquet"
val $csv = "$tmp/people.csv"

# ── DuckDB::execute ──
DuckDB::execute("CREATE TABLE people (id INT, name VARCHAR, score DOUBLE)", db => $db)
DuckDB::execute("INSERT INTO people VALUES (1,'alice',98.5),(2,'bob',87.0)", db => $db)
p "DuckDB::execute CREATE+INSERT ok"
val ($ex) = DuckDB::execute("UPDATE people SET score = score + ? WHERE id = ?",
    bind => [0.5, 2], db => $db)
p "DuckDB::execute bind affected=$ex->{affected_rows}"

Arrow::Parquet::write($pq, [
    { id => 3, name => "charlie", score => 91.2 },
    { id => 4, name => "dana",    score => 76.8 },
])
Arrow::CSV::write($csv, [
    { id => 5, name => "eve", score => 100.0 },
])

p "parquet external count=" .
    DuckDB::query_scalar("SELECT COUNT(*) FROM '$pq'", db => $db)

# ── DuckDB::import ──
DuckDB::import($pq, "imported_pq", kind => "parquet", db => $db)
p "DuckDB::import parquet rows=" .
    DuckDB::query_scalar("SELECT COUNT(*) FROM imported_pq", db => $db)
DuckDB::import($csv, "imported_csv", kind => "csv", replace => 1, db => $db)
p "DuckDB::import csv replace rows=" .
    DuckDB::query_scalar("SELECT COUNT(*) FROM imported_csv", db => $db)

# ── DuckDB::tables ──
p "DuckDB::tables " . join(",", DuckDB::tables(db => $db))

# ── DuckDB::schema ──
val ($sch) = DuckDB::schema("people", db => $db)
p "DuckDB::schema people cols: " . join(",", map { $_->{name} } @{ $sch->{columns} })

# ── DuckDB::dump ──
val @dump = DuckDB::dump("people", db => $db, order_by => "score DESC", limit => 2)
p "DuckDB::dump table order+limit #{len(@dump)} rows"
val @dump2 = DuckDB::dump($pq, db => $db, columns => "id,name", where => "score > 80")
p "DuckDB::dump parquet path where+columns #{len(@dump2)} rows"

# ── DuckDB::export ──
val $out = "$tmp/out.parquet"
DuckDB::export("people", $out, kind => "parquet", db => $db)
p "DuckDB::export parquet wrote $out"
val $out_csv = "$tmp/out.csv"
DuckDB::export("people", $out_csv, kind => "csv", db => $db)
p "DuckDB::export csv wrote $out_csv"

# ── DuckDB::inspect (file db) ──
val ($fi) = DuckDB::inspect(db => $db)
p "DuckDB::inspect file size=$fi->{file_size}"

# ── DuckDB::exec_file ──
val $sql = "/tmp/stryke-demo-duck-$$.sql"
open val $fh, ">", $sql or die $!
print $fh "UPDATE people SET score = score + 1 WHERE name = 'bob';\n"
print $fh "UPDATE people SET score = score + 1 WHERE name = 'alice';\n"
close $fh
val @ef = DuckDB::exec_file($sql, db => $db)
p "DuckDB::exec_file #{len(@ef)} stmt(s)"
unlink $sql

# ── DuckDB::export (compression) ──
val $out_zstd = "$tmp/out-zstd.parquet"
DuckDB::export("people", $out_zstd, kind => "parquet", compression => "zstd", db => $db)
p "DuckDB::export parquet zstd compression"

# ── DuckDB::dump (SQL table with where) ──
val @dump3 = DuckDB::dump("people", db => $db,
    where => "score >= 90", columns => "name,score", order_by => "score DESC")
p "DuckDB::dump where+columns #{len(@dump3)} rows"

# ── DuckDB::import (auto kind) ──
DuckDB::import($csv, "imported_csv2", kind => "auto", db => $db)
p "DuckDB::import auto csv rows=" .
    DuckDB::query_scalar("SELECT COUNT(*) FROM imported_csv2", db => $db)

# ── DuckDB::query_stream (bind+limit) ──
val $dsn = DuckDB::query_stream("SELECT n FROM range(?) AS t(n) WHERE n > ?",
    bind => [20, 15], limit => 3, db => $db,
    callback => fn ($r) { p "  bind stream n=$r->{n}" })
p "DuckDB::query_stream bind $dsn rows"

# ── DuckDB::execute (bind update) ──
val ($ex3) = DuckDB::execute("UPDATE people SET score = ? WHERE name = ?",
    bind => [99.0, "alice"], db => $db)
p "DuckDB::execute bind update affected=$ex3->{affected_rows}"

# ── DuckDB::tables (file db) ──
p "DuckDB::tables file db: " . join(",", DuckDB::tables(db => $db))

# ── DuckDB::schema (imported table) ──
val ($sch2) = DuckDB::schema("imported_pq", db => $db)
p "DuckDB::schema imported_pq cols=#{len($sch2->{columns} // [])}"

# ── DuckDB::query (with_meta file db) ──
val ($meta3) = DuckDB::query("SELECT * FROM people", with_meta => 1, db => $db, limit => 2)
p "DuckDB::query with_meta file db rows=#{len($meta3->{rows})}"

# ── DuckDB::inspect (re-check) ──
val ($fi2) = DuckDB::inspect(db => $db)
p "DuckDB::inspect final size=$fi2->{file_size}"

# ── DuckDB::query_col (file db) ──
val @names = DuckDB::query_col("SELECT name FROM people ORDER BY name", db => $db)
p "DuckDB::query_col names=" . join(",", @names)

unlink $db if -e $db
unlink "$db.wal" if -e "$db.wal"
unlink $pq if -e $pq
unlink $csv if -e $csv
unlink $out if -e $out
unlink $out_csv if -e $out_csv
unlink $out_zstd if -e $out_zstd
p "done"
